<h4>&#128024; MySQLGenius</h4>

<div class="mg-tabs">
  <button class="mg-tab active" data-tab="visual">Visual Builder</button>
  <button class="mg-tab" data-tab="sql">SQL Query</button>
  <button class="mg-tab" data-tab="slow">Slow Queries</button>
  <button class="mg-tab" data-tab="indexes">Duplicate Indexes</button>
  <button class="mg-tab" data-tab="sizes">Table Sizes</button>
  <button class="mg-tab" data-tab="qstats">Query Stats</button>
  <button class="mg-tab" data-tab="unused">Unused Indexes</button>
  <button class="mg-tab" data-tab="server">Server</button>
  <% if @ai_enabled %>
    <button class="mg-tab" data-tab="aitools">AI Tools</button>
  <% end %>
</div>

<!-- Visual Builder Tab -->
<div class="mg-tab-content active" id="tab-visual">
  <div class="mg-row mg-mb">
    <div class="mg-col-4 mg-field">
      <label for="vb-table">Table</label>
      <select id="vb-table">
        <option value="">-- Select a table --</option>
        <% if @featured_tables != @all_tables %>
          <optgroup label="Featured">
            <% @featured_tables.each do |table| %>
              <option value="<%= table %>"><%= table %></option>
            <% end %>
          </optgroup>
          <optgroup label="All Tables">
            <% (@all_tables - @featured_tables).each do |table| %>
              <option value="<%= table %>"><%= table %></option>
            <% end %>
          </optgroup>
        <% else %>
          <% @all_tables.each do |table| %>
            <option value="<%= table %>"><%= table %></option>
          <% end %>
        <% end %>
      </select>
    </div>
    <div class="mg-col-2 mg-field">
      <label for="vb-row-limit">Row Limit</label>
      <input type="number" id="vb-row-limit" value="25" min="1" max="<%= MysqlGenius.configuration.max_row_limit %>">
    </div>
    <div class="mg-field">
      <label>&nbsp;</label>
      <button id="vb-run" class="mg-btn mg-btn-primary" disabled>&#9654; Run Query</button>
      <button id="vb-explain" class="mg-btn mg-btn-outline" disabled>&#128270; Explain</button>
    </div>
  </div>

  <div id="vb-columns-section" class="mg-mb mg-hidden">
    <label>Columns
      <span id="vb-toggle-all" class="mg-link">Toggle All</span>
      <span id="vb-show-defaults" class="mg-link">Reset Defaults</span>
    </label>
    <div id="vb-columns" class="mg-checks"></div>
  </div>

  <div id="vb-filters-section" class="mg-mb mg-hidden">
    <label>Filters</label>
    <div id="vb-filters"></div>
    <button id="vb-add-filter" class="mg-btn mg-btn-outline-secondary mg-btn-sm" style="margin-top:4px;">+ Add Filter</button>
  </div>

  <div id="vb-order-section" class="mg-mb mg-hidden">
    <label>Order By</label>
    <div id="vb-orders"></div>
    <button id="vb-add-order" class="mg-btn mg-btn-outline-secondary mg-btn-sm" style="margin-top:4px;">+ Add Sort</button>
  </div>

  <div id="vb-generated-sql" class="mg-mb mg-hidden">
    <label>Generated SQL</label>
    <textarea id="vb-sql-preview" rows="2" readonly></textarea>
  </div>
</div>

<!-- SQL Query Tab -->
<div class="mg-tab-content" id="tab-sql">
  <% if @ai_enabled %>
    <div class="mg-card mg-mb">
      <div class="mg-card-header">
        <span class="mg-card-toggle" id="ai-toggle">&#9889; AI Assistant <span class="mg-text-muted">- Describe what you want in plain English</span></span>
      </div>
      <div class="mg-card-body mg-hidden" id="ai-panel">
        <div class="mg-field">
          <textarea id="ai-prompt" rows="2" placeholder="e.g. Show me all users created in the last 30 days"></textarea>
          <div class="mg-text-muted" style="margin-top:2px;">Only table names and column names are sent to the AI. No row data leaves the system.</div>
        </div>
        <button id="ai-suggest" class="mg-btn mg-btn-primary mg-btn-sm mg-mb">&#9889; Suggest Query</button>
        <div id="ai-result" class="mg-hidden">
          <div id="ai-explanation" class="mg-alert mg-alert-info"></div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="mg-field">
    <label for="sql-input">SQL Query</label>
    <textarea id="sql-input" rows="5" placeholder="SELECT * FROM users LIMIT 10"></textarea>
  </div>
  <div class="mg-row">
    <div class="mg-col-2 mg-field">
      <label for="sql-row-limit">Row Limit</label>
      <input type="number" id="sql-row-limit" value="25" min="1" max="<%= MysqlGenius.configuration.max_row_limit %>">
    </div>
    <div class="mg-field">
      <label>&nbsp;</label>
      <button id="sql-run" class="mg-btn mg-btn-primary">&#9654; Run Query</button>
      <button id="sql-explain" class="mg-btn mg-btn-outline">&#128270; Explain</button>
      <% if @ai_enabled %>
        <button id="sql-describe" class="mg-btn mg-btn-outline mg-btn-sm" style="margin-left:8px;">&#9889; Describe</button>
        <button id="sql-rewrite" class="mg-btn mg-btn-outline mg-btn-sm">&#9889; Rewrite</button>
      <% end %>
    </div>
  </div>
</div>

<!-- Slow Queries Tab -->
<div class="mg-tab-content" id="tab-slow">
  <div class="mg-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
    <div class="mg-text-muted">SELECT queries exceeding <%= MysqlGenius.configuration.slow_query_threshold_ms %>ms. <span id="slow-count" class="mg-badge mg-badge-secondary"></span></div>
    <button id="slow-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#8635; Refresh</button>
  </div>
  <div id="slow-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Loading...</div>
  <div id="slow-empty" class="mg-text-center mg-text-muted mg-hidden">No slow queries recorded.</div>
  <div id="slow-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead>
        <tr><th style="width:100px">Duration</th><th style="width:160px">Time</th><th>SQL</th><th style="width:150px">Actions</th></tr>
      </thead>
      <tbody id="slow-tbody"></tbody>
    </table>
  </div>
</div>

<!-- Duplicate Indexes Tab -->
<div class="mg-tab-content" id="tab-indexes">
  <div class="mg-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
    <div class="mg-text-muted">Indexes whose columns are a left-prefix of another index on the same table. These are redundant and can safely be dropped. <span id="dup-count" class="mg-badge mg-badge-secondary"></span></div>
    <button id="dup-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#8635; Refresh</button>
  </div>
  <div id="dup-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Scanning indexes...</div>
  <div id="dup-empty" class="mg-text-center mg-text-muted mg-hidden">No duplicate indexes found.</div>
  <div id="dup-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead>
        <tr>
          <th>Table</th>
          <th>Duplicate Index</th>
          <th>Columns</th>
          <th>Covered By</th>
          <th>Covered Columns</th>
          <th>DROP Statement</th>
        </tr>
      </thead>
      <tbody id="dup-tbody"></tbody>
    </table>
  </div>
</div>

<!-- Table Sizes Tab -->
<div class="mg-tab-content" id="tab-sizes">
  <div class="mg-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
    <div class="mg-text-muted">Table sizes from <code>information_schema</code>, sorted by total size. Row counts are estimates. <span id="sizes-total" class="mg-badge mg-badge-secondary"></span></div>
    <button id="sizes-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#8635; Refresh</button>
  </div>
  <div id="sizes-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Loading...</div>
  <div id="sizes-chart-wrapper" class="mg-hidden" style="margin-bottom:16px;">
    <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;">
      <canvas id="sizes-pie" width="280" height="280" style="flex-shrink:0;"></canvas>
      <div id="sizes-legend" style="font-size:12px;line-height:1.8;"></div>
    </div>
  </div>
  <div id="sizes-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead>
        <tr>
          <th>Table</th>
          <th style="text-align:right">Rows (est.)</th>
          <th style="text-align:right">Data</th>
          <th style="text-align:right">Indexes</th>
          <th style="text-align:right">Total</th>
          <th style="text-align:right">Fragmented</th>
          <th style="width:200px"></th>
        </tr>
      </thead>
      <tbody id="sizes-tbody"></tbody>
    </table>
  </div>

</div>

<!-- Query Stats Tab -->
<div class="mg-tab-content" id="tab-qstats">
  <div class="mg-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
    <div class="mg-text-muted">Top queries from <code>performance_schema.events_statements_summary_by_digest</code>. <span id="qstats-count" class="mg-badge mg-badge-secondary"></span></div>
    <div>
      <label style="display:inline;font-size:12px;margin-right:4px;">Sort by:</label>
      <select id="qstats-sort" style="width:auto;display:inline-block;padding:3px 6px;font-size:12px;">
        <option value="total_time">Total Time</option>
        <option value="avg_time">Avg Time</option>
        <option value="calls">Calls</option>
        <option value="rows_examined">Rows Examined</option>
      </select>
      <button id="qstats-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm" style="margin-left:4px;">&#8635; Refresh</button>
    </div>
  </div>
  <div id="qstats-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Loading...</div>
  <div id="qstats-error" class="mg-hidden"></div>
  <div id="qstats-empty" class="mg-text-center mg-text-muted mg-hidden">No query statistics available.</div>
  <div id="qstats-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead>
        <tr>
          <th>Query</th>
          <th style="text-align:right">Calls</th>
          <th style="text-align:right">Total Time</th>
          <th style="text-align:right">Avg Time</th>
          <th style="text-align:right">Max Time</th>
          <th style="text-align:right">Rows Examined</th>
          <th style="text-align:right">Rows Sent</th>
          <th style="text-align:right">Exam/Sent</th>
        </tr>
      </thead>
      <tbody id="qstats-tbody"></tbody>
    </table>
  </div>
</div>

<!-- Unused Indexes Tab -->
<div class="mg-tab-content" id="tab-unused">
  <div class="mg-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
    <div class="mg-text-muted">Indexes with zero reads since last server restart, from <code>performance_schema</code>. <span id="unused-count" class="mg-badge mg-badge-secondary"></span></div>
    <button id="unused-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#8635; Refresh</button>
  </div>
  <div id="unused-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Scanning...</div>
  <div id="unused-error" class="mg-hidden"></div>
  <div id="unused-empty" class="mg-text-center mg-text-muted mg-hidden">No unused indexes found.</div>
  <div id="unused-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead>
        <tr>
          <th>Table</th>
          <th>Index</th>
          <th style="text-align:right">Reads</th>
          <th style="text-align:right">Writes</th>
          <th style="text-align:right">Table Rows</th>
          <th>DROP Statement</th>
        </tr>
      </thead>
      <tbody id="unused-tbody"></tbody>
    </table>
  </div>
</div>

<!-- Server Tab -->
<div class="mg-tab-content" id="tab-server">
  <div class="mg-row" style="justify-content:flex-end;margin-bottom:12px;">
    <% if @ai_enabled %>
      <button id="server-root-cause" class="mg-btn mg-btn-primary mg-btn-sm">&#9889; Why is it slow?</button>
      <button id="server-anomaly" class="mg-btn mg-btn-outline mg-btn-sm">&#9889; Anomaly Detection</button>
    <% end %>
    <button id="server-refresh" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#8635; Refresh</button>
  </div>
  <div id="server-loading" class="mg-text-center mg-hidden"><span class="mg-spinner"></span> Loading...</div>
  <div id="server-error" class="mg-hidden"></div>
  <div id="server-content" class="mg-hidden">
    <!-- Server Info -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:12px;margin-bottom:16px;">
      <div class="mg-card">
        <div class="mg-card-header"><strong>Server</strong></div>
        <div class="mg-card-body">
          <div class="mg-stat-grid" id="server-info"></div>
        </div>
      </div>
      <div class="mg-card">
        <div class="mg-card-header"><strong>Connections</strong></div>
        <div class="mg-card-body">
          <div id="conn-bar" style="margin-bottom:8px;"></div>
          <div class="mg-stat-grid" id="conn-info"></div>
        </div>
      </div>
      <div class="mg-card">
        <div class="mg-card-header"><strong>InnoDB Buffer Pool</strong></div>
        <div class="mg-card-body">
          <div id="innodb-bar" style="margin-bottom:8px;"></div>
          <div class="mg-stat-grid" id="innodb-info"></div>
        </div>
      </div>
      <div class="mg-card">
        <div class="mg-card-header"><strong>Query Activity</strong></div>
        <div class="mg-card-body">
          <div class="mg-stat-grid" id="query-info"></div>
        </div>
      </div>
    </div>
    <div id="server-ai-result" class="mg-mt mg-hidden">
      <div class="mg-card">
        <div class="mg-card-header">
          <span id="server-ai-title"><strong>&#9889; AI Analysis</strong></span>
          <button id="server-ai-close" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#10005;</button>
        </div>
        <div class="mg-card-body">
          <div id="server-ai-content" style="font-size:13px;"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- AI Tools Tab -->
<% if @ai_enabled %>
<div class="mg-tab-content" id="tab-aitools">
  <!-- Schema Review -->
  <div class="mg-card mg-mb">
    <div class="mg-card-header"><strong>&#9889; Schema Review</strong></div>
    <div class="mg-card-body">
      <div class="mg-text-muted mg-mb" style="font-size:12px;">Analyze your schema for anti-patterns: inappropriate column types, missing indexes, naming inconsistencies, and more.</div>
      <div class="mg-row" style="align-items:flex-end;">
        <div class="mg-col-4 mg-field">
          <label for="schema-table">Table (leave blank for all)</label>
          <select id="schema-table">
            <option value="">All tables (top 20)</option>
            <% @all_tables.each do |table| %>
              <option value="<%= table %>"><%= table %></option>
            <% end %>
          </select>
        </div>
        <div class="mg-field">
          <button id="schema-review-btn" class="mg-btn mg-btn-primary mg-btn-sm">&#9889; Analyze Schema</button>
        </div>
      </div>
      <div id="schema-result" class="mg-mt mg-hidden">
        <div id="schema-result-content" class="mg-alert mg-alert-info" style="font-size:13px;"></div>
      </div>
    </div>
  </div>

  <!-- Migration Risk Assessment -->
  <div class="mg-card">
    <div class="mg-card-header"><strong>&#9889; Migration Risk Assessment</strong></div>
    <div class="mg-card-body">
      <div class="mg-text-muted mg-mb" style="font-size:12px;">Paste a Rails migration or DDL and get a risk assessment: lock duration, impact on active queries, deployment strategy.</div>
      <div class="mg-field">
        <textarea id="migration-input" rows="8" placeholder="class AddIndexToUsers < ActiveRecord::Migration[7.0]&#10;  def change&#10;    add_index :users, :email, unique: true&#10;  end&#10;end"></textarea>
      </div>
      <button id="migration-assess-btn" class="mg-btn mg-btn-primary mg-btn-sm">&#9889; Assess Risk</button>
      <div id="migration-result" class="mg-mt mg-hidden">
        <div id="migration-risk-badge" style="margin-bottom:8px;"></div>
        <div id="migration-result-content" class="mg-alert mg-alert-info" style="font-size:13px;"></div>
      </div>
    </div>
  </div>
</div>
<% end %>

<!-- Explain Results -->
<div id="explain-results" class="mg-mt mg-hidden">
  <div class="mg-card">
    <div class="mg-card-header">
      <span><strong>&#128270; EXPLAIN Output</strong></span>
      <div>
        <% if @ai_enabled %>
          <button id="explain-optimize" class="mg-btn mg-btn-outline mg-btn-sm">&#9889; AI Optimization</button>
          <button id="explain-index-advisor" class="mg-btn mg-btn-outline mg-btn-sm">&#9889; Index Advisor</button>
        <% end %>
        <button id="explain-close" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#10005; Close</button>
      </div>
    </div>
    <div class="mg-card-body">
      <div class="mg-table-wrap">
        <table class="mg-table">
          <thead id="explain-thead"></thead>
          <tbody id="explain-tbody"></tbody>
        </table>
      </div>
      <div id="optimize-results" class="mg-hidden mg-mt">
        <div id="optimize-content" class="mg-alert mg-alert-info"></div>
      </div>
    </div>
  </div>
</div>

<!-- Results Area -->
<div id="query-results" class="mg-mt">
  <div id="results-alert" class="mg-hidden"></div>
  <div id="results-stats" class="mg-mb mg-hidden">
    <span id="results-row-count" class="mg-badge mg-badge-info"></span>
    <span id="results-time" class="mg-badge mg-badge-secondary"></span>
    <span id="results-truncated" class="mg-badge mg-badge-warning mg-hidden">Results truncated</span>
  </div>
  <div id="results-table-wrapper" class="mg-table-wrap mg-hidden">
    <table class="mg-table">
      <thead id="results-thead"></thead>
      <tbody id="results-tbody"></tbody>
    </table>
  </div>
  <div id="results-empty" class="mg-text-center mg-text-muted mg-hidden">No rows returned.</div>
</div>

<!-- AI Query Analysis Results -->
<div id="ai-query-result" class="mg-mt mg-hidden">
  <div class="mg-card">
    <div class="mg-card-header">
      <span id="ai-query-title"><strong>&#9889; AI Analysis</strong></span>
      <button id="ai-query-close" class="mg-btn mg-btn-outline-secondary mg-btn-sm">&#10005;</button>
    </div>
    <div class="mg-card-body">
      <div id="ai-query-content" style="font-size:13px;"></div>
    </div>
  </div>
</div>

<script>
(function() {
  "use strict";

  var ROUTES = {
    columns:      '<%= mysql_genius.columns_path %>',
    execute:      '<%= mysql_genius.execute_path %>',
    explain:      '<%= mysql_genius.explain_path %>',
    suggest:      '<%= mysql_genius.suggest_path %>',
    optimize:     '<%= mysql_genius.optimize_path %>',
    slow_queries: '<%= mysql_genius.slow_queries_path %>',
    duplicate_indexes: '<%= mysql_genius.duplicate_indexes_path %>',
    table_sizes: '<%= mysql_genius.table_sizes_path %>',
    query_stats: '<%= mysql_genius.query_stats_path %>',
    unused_indexes: '<%= mysql_genius.unused_indexes_path %>',
    server_overview: '<%= mysql_genius.server_overview_path %>',
    describe_query: '<%= mysql_genius.describe_query_path %>',
    schema_review: '<%= mysql_genius.schema_review_path %>',
    rewrite_query: '<%= mysql_genius.rewrite_query_path %>',
    index_advisor: '<%= mysql_genius.index_advisor_path %>',
    anomaly_detection: '<%= mysql_genius.anomaly_detection_path %>',
    root_cause: '<%= mysql_genius.root_cause_path %>',
    migration_risk: '<%= mysql_genius.migration_risk_path %>'
  };

  var csrfMeta = document.querySelector('meta[name="csrf-token"]');
  var csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : '';
  var currentColumns = [];
  var columnTypeMap = {};
  var lastExplainSql = '';
  var lastExplainRows = [];

  // --- Helpers ---

  function el(id) { return document.getElementById(id); }
  function qs(sel, parent) { return (parent || document).querySelector(sel); }
  function qsa(sel, parent) { return Array.from((parent || document).querySelectorAll(sel)); }
  function show(e) { e.classList.remove('mg-hidden'); }
  function hide(e) { e.classList.add('mg-hidden'); }
  function escHtml(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function ajax(method, url, data, onSuccess, onError) {
    var xhr = new XMLHttpRequest();
    xhr.open(method, url, true);
    xhr.setRequestHeader('X-CSRF-Token', csrfToken);
    xhr.setRequestHeader('Accept', 'application/json');
    xhr.onload = function() {
      var json;
      try { json = JSON.parse(xhr.responseText); } catch(e) { json = null; }
      if (xhr.status >= 200 && xhr.status < 300) {
        onSuccess(json);
      } else {
        (onError || function(){})(json, xhr.status);
      }
    };
    xhr.onerror = function() { (onError || function(){})(null, 0); };
    if (data && method !== 'GET') {
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      var parts = [];
      for (var k in data) {
        if (Array.isArray(data[k])) {
          data[k].forEach(function(v, i) {
            if (typeof v === 'object') {
              for (var vk in v) parts.push(encodeURIComponent(k + '[' + i + '][' + vk + ']') + '=' + encodeURIComponent(v[vk]));
            } else {
              parts.push(encodeURIComponent(k + '[]') + '=' + encodeURIComponent(v));
            }
          });
        } else {
          parts.push(encodeURIComponent(k) + '=' + encodeURIComponent(data[k]));
        }
      }
      xhr.send(parts.join('&'));
    } else if (method === 'GET' && data) {
      // data is already in the URL
      xhr.send();
    } else {
      xhr.send();
    }
  }

  function ajaxGet(url, params, onSuccess, onError) {
    var query = Object.keys(params).map(function(k) {
      return encodeURIComponent(k) + '=' + encodeURIComponent(params[k]);
    }).join('&');
    ajax('GET', url + '?' + query, null, onSuccess, onError);
  }

  // --- Tabs ---

  qsa('.mg-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      qsa('.mg-tab').forEach(function(t) { t.classList.remove('active'); });
      qsa('.mg-tab-content').forEach(function(c) { c.classList.remove('active'); });
      tab.classList.add('active');
      el('tab-' + tab.dataset.tab).classList.add('active');
      if (tab.dataset.tab === 'slow') loadSlowQueries();
      if (tab.dataset.tab === 'indexes') loadDuplicateIndexes();
      if (tab.dataset.tab === 'sizes') loadTableSizes();
      if (tab.dataset.tab === 'qstats') loadQueryStats();
      if (tab.dataset.tab === 'unused') loadUnusedIndexes();
      if (tab.dataset.tab === 'server') loadServerOverview();
    });
  });

  // --- Visual Builder ---

  var typeLabels = { string: 'text', text: 'text', integer: 'number', boolean: 'yes/no', date: 'date', datetime: 'date/time', decimal: 'decimal', float: 'decimal' };
  function colTypeLabel(type) { return typeLabels[type] || type; }

  function operatorsForType(type) {
    switch(type) {
      case 'boolean': return ['=', '!=', 'IS NULL', 'IS NOT NULL'];
      case 'date': case 'datetime': return ['=', '!=', '>', '<', '>=', '<=', 'BETWEEN', 'IS NULL', 'IS NOT NULL'];
      case 'integer': case 'decimal': case 'float': return ['=', '!=', '>', '<', '>=', '<=', 'IS NULL', 'IS NOT NULL'];
      default: return ['=', '!=', 'LIKE', '>', '<', 'IS NULL', 'IS NOT NULL'];
    }
  }

  function loadColumnsForTable(table, callback) {
    el('vb-columns').innerHTML = '';
    el('vb-filters').innerHTML = '';
    el('vb-orders').innerHTML = '';
    columnTypeMap = {};
    if (!table) {
      hide(el('vb-columns-section')); hide(el('vb-filters-section'));
      hide(el('vb-order-section')); hide(el('vb-generated-sql'));
      el('vb-run').disabled = true; el('vb-explain').disabled = true;
      return;
    }
    ajaxGet(ROUTES.columns, { table: table }, function(cols) {
      currentColumns = cols;
      cols.forEach(function(c) { columnTypeMap[c.name] = c.type; });
      var html = '';
      cols.forEach(function(col) {
        var checked = col['default'] ? ' checked' : '';
        html += '<label class="mg-check"><input type="checkbox" class="vb-col-check" value="' + escHtml(col.name) + '"' + checked +
          ' data-default="' + (col['default'] ? '1' : '0') + '">' + escHtml(col.name) +
          ' <span class="type-hint">(' + colTypeLabel(col.type) + ')</span></label>';
      });
      el('vb-columns').innerHTML = html;
      show(el('vb-columns-section')); show(el('vb-filters-section'));
      show(el('vb-order-section')); show(el('vb-generated-sql'));
      el('vb-run').disabled = false; el('vb-explain').disabled = false;
      if (callback) callback(cols); else updateGeneratedSql();
    });
  }

  el('vb-table').addEventListener('change', function() { loadColumnsForTable(this.value); });

  el('vb-toggle-all').addEventListener('click', function() {
    var checks = qsa('.vb-col-check');
    var allChecked = checks.every(function(c) { return c.checked; });
    checks.forEach(function(c) { c.checked = !allChecked; });
    updateGeneratedSql();
  });

  el('vb-show-defaults').addEventListener('click', function() {
    qsa('.vb-col-check').forEach(function(c) { c.checked = c.dataset['default'] === '1'; });
    updateGeneratedSql();
  });

  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('vb-col-check')) updateGeneratedSql();
  });

  function columnOptions(useAll) {
    var cols = useAll ? currentColumns : currentColumns.filter(function(c) { return c['default']; });
    var html = '<option value="">-- column --</option>';
    cols.forEach(function(c) { html += '<option value="' + escHtml(c.name) + '">' + escHtml(c.name) + ' (' + colTypeLabel(c.type) + ')</option>'; });
    return html;
  }

  function addFilterRow(useAll) {
    var div = document.createElement('div');
    div.className = 'mg-row mg-mb vb-filter-row';
    div.style.alignItems = 'center';
    div.innerHTML =
      '<div class="mg-col-3"><select class="vb-filter-col">' + columnOptions(useAll) + '</select></div>' +
      '<div class="mg-col-2"><select class="vb-filter-op"><option>=</option><option>!=</option><option>LIKE</option><option>></option><option><</option><option>IS NULL</option><option>IS NOT NULL</option></select></div>' +
      '<div class="mg-col-4 vb-filter-val-container"><input type="text" class="vb-filter-val" placeholder="value"></div>' +
      '<div><button class="mg-btn mg-btn-outline-danger mg-btn-sm vb-remove-filter">&#10005;</button></div>';
    el('vb-filters').appendChild(div);
  }

  el('vb-add-filter').addEventListener('click', function() { addFilterRow(false); updateGeneratedSql(); });

  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('vb-filter-col')) {
      var row = e.target.closest('.vb-filter-row');
      var colType = columnTypeMap[e.target.value] || 'string';
      var opSel = qs('.vb-filter-op', row);
      var ops = operatorsForType(colType);
      opSel.innerHTML = ops.map(function(o) { return '<option>' + o + '</option>'; }).join('');
      updateValueInput(row, colType, opSel.value);
      updateGeneratedSql();
    }
    if (e.target.classList.contains('vb-filter-op')) {
      var row = e.target.closest('.vb-filter-row');
      var colName = qs('.vb-filter-col', row).value;
      var colType = columnTypeMap[colName] || 'string';
      updateValueInput(row, colType, e.target.value);
      updateGeneratedSql();
    }
  });

  document.addEventListener('input', function(e) {
    if (e.target.classList.contains('vb-filter-val')) updateGeneratedSql();
  });

  document.addEventListener('click', function(e) {
    if (e.target.closest('.vb-remove-filter')) { e.target.closest('.vb-filter-row').remove(); updateGeneratedSql(); }
    if (e.target.closest('.vb-remove-order')) { e.target.closest('.vb-order-row').remove(); updateGeneratedSql(); }
  });

  function updateValueInput(row, colType, op) {
    var container = qs('.vb-filter-val-container', row);
    if (op === 'IS NULL' || op === 'IS NOT NULL') { container.innerHTML = ''; return; }
    if (colType === 'boolean') {
      container.innerHTML = '<select class="vb-filter-val"><option value="1">True</option><option value="0">False</option></select>';
    } else if ((colType === 'date' || colType === 'datetime') && op === 'BETWEEN') {
      container.innerHTML = '<input type="date" class="vb-filter-val" style="width:45%;display:inline-block;"> <span class="mg-text-muted">and</span> <input type="date" class="vb-filter-val-end" style="width:45%;display:inline-block;">';
    } else if (colType === 'date' || colType === 'datetime') {
      container.innerHTML = '<input type="date" class="vb-filter-val">';
    } else if (colType === 'integer') {
      container.innerHTML = '<input type="number" class="vb-filter-val" placeholder="number" step="1">';
    } else if (colType === 'decimal' || colType === 'float') {
      container.innerHTML = '<input type="number" class="vb-filter-val" placeholder="number" step="any">';
    } else {
      var ph = (op === 'LIKE') ? 'use % as wildcard' : 'value';
      container.innerHTML = '<input type="text" class="vb-filter-val" placeholder="' + ph + '">';
    }
  }

  // --- Order By ---

  function addOrderRow(useAll) {
    var cols = useAll ? currentColumns : currentColumns.filter(function(c) { return c['default']; });
    var options = '<option value="">-- column --</option>';
    cols.forEach(function(c) { options += '<option value="' + escHtml(c.name) + '">' + escHtml(c.name) + '</option>'; });
    var div = document.createElement('div');
    div.className = 'mg-row mg-mb vb-order-row';
    div.style.alignItems = 'center';
    div.innerHTML =
      '<div class="mg-col-3"><select class="vb-order-col">' + options + '</select></div>' +
      '<div class="mg-col-2"><select class="vb-order-dir"><option value="ASC">Ascending</option><option value="DESC">Descending</option></select></div>' +
      '<div><button class="mg-btn mg-btn-outline-danger mg-btn-sm vb-remove-order">&#10005;</button></div>';
    el('vb-orders').appendChild(div);
  }

  el('vb-add-order').addEventListener('click', function() { addOrderRow(false); updateGeneratedSql(); });

  document.addEventListener('change', function(e) {
    if (e.target.classList.contains('vb-order-col') || e.target.classList.contains('vb-order-dir')) updateGeneratedSql();
  });

  // --- Build SQL ---

  function buildSql() {
    var table = el('vb-table').value;
    if (!table) return '';
    var cols = [];
    qsa('.vb-col-check:checked').forEach(function(c) { cols.push('`' + c.value + '`'); });
    if (!cols.length) cols = ['*'];
    var sql = 'SELECT ' + cols.join(', ') + ' FROM `' + table + '`';
    var wheres = [];
    qsa('.vb-filter-row').forEach(function(row) {
      var col = qs('.vb-filter-col', row).value;
      var op = qs('.vb-filter-op', row).value;
      var valEl = qs('.vb-filter-val', row);
      var val = valEl ? valEl.value : '';
      if (!col) return;
      if (op === 'IS NULL' || op === 'IS NOT NULL') {
        wheres.push('`' + col + '` ' + op);
      } else if (op === 'BETWEEN') {
        var endEl = qs('.vb-filter-val-end', row);
        var endVal = endEl ? endEl.value : '';
        wheres.push("`" + col + "` BETWEEN '" + val.replace(/'/g, "''") + "' AND '" + endVal.replace(/'/g, "''") + "'");
      } else if (op === 'LIKE') {
        wheres.push("`" + col + "` LIKE '" + val.replace(/'/g, "''") + "'");
      } else {
        wheres.push("`" + col + "` " + op + " '" + val.replace(/'/g, "''") + "'");
      }
    });
    if (wheres.length) sql += ' WHERE ' + wheres.join(' AND ');
    var orders = [];
    qsa('.vb-order-row').forEach(function(row) {
      var col = qs('.vb-order-col', row).value;
      var dir = qs('.vb-order-dir', row).value;
      if (col) orders.push('`' + col + '` ' + dir);
    });
    if (orders.length) sql += ' ORDER BY ' + orders.join(', ');
    return sql;
  }

  function updateGeneratedSql() {
    var sql = buildSql();
    el('vb-sql-preview').value = sql;
    el('sql-input').value = sql;
  }

  // --- Run Query ---

  el('vb-run').addEventListener('click', function() {
    var sql = buildSql();
    if (sql) runQuery(sql, parseInt(el('vb-row-limit').value) || 25);
  });

  el('sql-run').addEventListener('click', function() {
    var sql = el('sql-input').value.trim();
    if (sql) runQuery(sql, parseInt(el('sql-row-limit').value) || 25);
  });

  el('sql-input').addEventListener('input', function() { el('vb-sql-preview').value = this.value; });

  function runQuery(sql, rowLimit) {
    clearResults();
    setBtnLoading(['vb-run', 'sql-run'], true);
    ajax('POST', ROUTES.execute, { sql: sql, row_limit: rowLimit }, function(data) {
      renderResults(data);
      setBtnLoading(['vb-run', 'sql-run'], false);
    }, function(json) {
      var cls = (json && json.timeout) ? 'mg-alert-warning' : 'mg-alert-danger';
      el('results-alert').innerHTML = '<div class="mg-alert ' + cls + '">' + escHtml((json && json.error) || 'An unexpected error occurred.') + '</div>';
      show(el('results-alert'));
      setBtnLoading(['vb-run', 'sql-run'], false);
    });
  }

  function clearResults() {
    hide(el('results-alert')); hide(el('results-stats'));
    hide(el('results-table-wrapper')); hide(el('results-empty'));
    hide(el('results-truncated'));
    el('results-thead').innerHTML = '';
    el('results-tbody').innerHTML = '';
  }

  function renderResults(data) {
    if (data.row_count === 0) {
      show(el('results-empty')); show(el('results-stats'));
      el('results-row-count').textContent = '0 rows';
      el('results-time').textContent = data.execution_time_ms + ' ms';
      return;
    }
    el('results-row-count').textContent = data.row_count + ' row' + (data.row_count !== 1 ? 's' : '');
    el('results-time').textContent = data.execution_time_ms + ' ms';
    if (data.truncated) show(el('results-truncated'));
    show(el('results-stats'));

    el('results-thead').innerHTML = '<tr>' + data.columns.map(function(c) { return '<th>' + escHtml(c) + '</th>'; }).join('') + '</tr>';
    el('results-tbody').innerHTML = data.rows.map(function(row) {
      return '<tr>' + row.map(function(val) {
        if (val === null) return '<td><em class="null">NULL</em></td>';
        if (val === '[REDACTED]') return '<td><span class="redacted">[REDACTED]</span></td>';
        return '<td>' + escHtml(String(val)) + '</td>';
      }).join('') + '</tr>';
    }).join('');
    show(el('results-table-wrapper'));
  }

  // --- Explain ---

  el('vb-explain').addEventListener('click', function() { var sql = buildSql(); if (sql) runExplain(sql); });
  el('sql-explain').addEventListener('click', function() { var sql = el('sql-input').value.trim(); if (sql) runExplain(sql); });
  el('explain-close').addEventListener('click', function() { hide(el('explain-results')); });

  function runExplain(sql, fromSlowQuery) {
    lastExplainSql = sql;
    hide(el('explain-results')); hide(el('optimize-results'));
    el('explain-thead').innerHTML = '';
    el('explain-tbody').innerHTML = '';
    setBtnLoading(['vb-explain', 'sql-explain'], true);

    var postData = { sql: sql };
    if (fromSlowQuery) postData.from_slow_query = 'true';
    ajax('POST', ROUTES.explain, postData, function(data) {
      lastExplainRows = data.rows;
      el('explain-thead').innerHTML = '<tr>' + data.columns.map(function(c) { return '<th>' + escHtml(c) + '</th>'; }).join('') + '</tr>';
      el('explain-tbody').innerHTML = data.rows.map(function(row) {
        return '<tr>' + row.map(function(val) {
          return val === null ? '<td><em class="null">NULL</em></td>' : '<td>' + escHtml(String(val)) + '</td>';
        }).join('') + '</tr>';
      }).join('');
      show(el('explain-results'));
      setBtnLoading(['vb-explain', 'sql-explain'], false);
    }, function(json) {
      el('results-alert').innerHTML = '<div class="mg-alert mg-alert-danger">' + escHtml((json && json.error) || 'Explain failed.') + '</div>';
      show(el('results-alert'));
      setBtnLoading(['vb-explain', 'sql-explain'], false);
    });
  }

  // --- AI ---

  var aiToggle = el('ai-toggle');
  if (aiToggle) {
    aiToggle.addEventListener('click', function() {
      var panel = el('ai-panel');
      panel.classList.toggle('mg-hidden');
    });
  }

  var aiSuggest = el('ai-suggest');
  if (aiSuggest) {
    aiSuggest.addEventListener('click', function() {
      var prompt = el('ai-prompt').value.trim();
      if (!prompt) return;
      aiSuggest.disabled = true;
      aiSuggest.innerHTML = '<span class="mg-spinner"></span> Thinking...';
      hide(el('ai-result'));

      ajax('POST', ROUTES.suggest, { prompt: prompt }, function(data) {
        el('sql-input').value = data.sql || '';
        if (data.explanation) {
          el('ai-explanation').textContent = data.explanation;
          show(el('ai-result'));
        }
        parseSqlToBuilder(data.sql);
        aiSuggest.disabled = false;
        aiSuggest.innerHTML = '&#9889; Suggest Query';
      }, function(json) {
        el('results-alert').innerHTML = '<div class="mg-alert mg-alert-danger">' + escHtml((json && json.error) || 'AI suggestion failed.') + '</div>';
        show(el('results-alert'));
        aiSuggest.disabled = false;
        aiSuggest.innerHTML = '&#9889; Suggest Query';
      });
    });
  }

  var explainOptimize = el('explain-optimize');
  if (explainOptimize) {
    explainOptimize.addEventListener('click', function() {
      explainOptimize.disabled = true;
      explainOptimize.innerHTML = '<span class="mg-spinner"></span> Analyzing...';
