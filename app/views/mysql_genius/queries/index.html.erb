      sqlRewrite.disabled = true;
      sqlRewrite.innerHTML = '<span class="mg-spinner"></span>';
      hide(el('ai-query-result'));
      aiCall(ROUTES.rewrite_query, { sql: sql }, function(data) {
        var html = '';
