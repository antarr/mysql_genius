  gem "rack-test"
  gem "rake"
  gem "rspec", "~> 3.0"
  gem "rubocop"
  gem "rubocop-rspec"
  gem "rubocop-shopify"
end

gem "rackup", "~> 2.3"
gem "puma", "~> 6.6"
