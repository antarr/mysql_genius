<h4>Connection Manager</h4>

<div class="mg-card mg-mb">
  <div class="mg-card-header" style="display:flex;justify-content:space-between;align-items:center;">
    <strong>Profiles</strong>
    <button id="mg-add-profile-btn" class="mg-btn mg-btn-primary mg-btn-sm">+ Add Profile</button>
  </div>
  <div class="mg-card-body">
    <div class="mg-table-wrap">
      <table class="mg-table" id="mg-profile-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Host</th>
            <th>Database</th>
            <th>Status</th>
            <th style="width:200px;">Actions</th>
          </tr>
        </thead>
        <tbody id="mg-profile-tbody">
          <tr><td colspan="5" class="mg-text-center"><span class="mg-spinner"></span> Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div id="mg-profile-form" class="mg-card mg-hidden">
  <div class="mg-card-header">
    <strong id="mg-form-title">Add Profile</strong>
    <button id="mg-form-cancel" class="mg-btn mg-btn-outline-secondary mg-btn-sm">Cancel</button>
  </div>
  <div class="mg-card-body">
    <div class="mg-row">
      <div class="mg-col-3 mg-field">
        <label for="mg-f-name">Profile Name</label>
        <input type="text" id="mg-f-name" placeholder="e.g. production">
      </div>
      <div class="mg-col-3 mg-field">
        <label for="mg-f-host">Host</label>
        <input type="text" id="mg-f-host" placeholder="127.0.0.1">
      </div>
      <div class="mg-col-1 mg-field">
        <label for="mg-f-port">Port</label>
        <input type="number" id="mg-f-port" value="3306">
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-3 mg-field">
        <label for="mg-f-username">Username</label>
        <input type="text" id="mg-f-username" placeholder="readonly">
      </div>
      <div class="mg-col-3 mg-field">
        <label for="mg-f-password">Password</label>
        <input type="text" id="mg-f-password" placeholder="(leave blank if none)">
      </div>
      <div class="mg-col-3 mg-field">
        <label for="mg-f-database">Database</label>
        <input type="text" id="mg-f-database" placeholder="app_production">
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-2 mg-field">
        <label for="mg-f-tls">TLS Mode</label>
        <select id="mg-f-tls">
          <option value="preferred" selected>Preferred</option>
          <option value="required">Required</option>
          <option value="disabled">Disabled</option>
        </select>
      </div>
      <div class="mg-field" style="display:flex;gap:8px;align-items:flex-end;">
        <button id="mg-form-test" class="mg-btn mg-btn-outline mg-btn-sm">Test Connection</button>
        <button id="mg-form-save" class="mg-btn mg-btn-primary mg-btn-sm">Save</button>
        <span id="mg-form-status" style="font-size:12px;"></span>
      </div>
    </div>
  </div>
</div>

<div class="mg-card mg-mb">
  <div class="mg-card-header" style="display:flex;justify-content:space-between;align-items:center;">
    <strong>AI Configuration</strong>
    <span id="mg-ai-status" style="font-size:12px;color:#888;">Loading...</span>
  </div>
  <div class="mg-card-body">
    <div class="mg-text-muted mg-mb" style="font-size:12px;">Connect to an OpenAI-compatible API for query suggestions, optimization, schema review, and more.</div>
    <div class="mg-row">
      <div class="mg-col-3 mg-field">
        <label for="mg-ai-provider">Provider</label>
        <select id="mg-ai-provider">
          <option value="anthropic">Anthropic</option>
          <option value="azure">Azure OpenAI</option>
          <option value="deepseek">DeepSeek</option>
          <option value="fireworks">Fireworks AI</option>
          <option value="google">Google Gemini</option>
          <option value="groq">Groq</option>
          <option value="lmstudio">LM Studio (local)</option>
          <option value="mistral">Mistral</option>
          <option value="ollama">Ollama (local)</option>
          <option value="openai">OpenAI</option>
          <option value="openrouter">OpenRouter</option>
          <option value="perplexity">Perplexity</option>
          <option value="together">Together</option>
          <option value="xai">xAI (Grok)</option>
          <option value="custom">Custom</option>
        </select>
      </div>
      <div class="mg-col-grow mg-field">
        <label for="mg-ai-endpoint">API Endpoint</label>
        <input type="text" id="mg-ai-endpoint" placeholder="https://api.openai.com/v1/chat/completions">
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-3 mg-field">
        <label for="mg-ai-key">API Key</label>
        <input type="password" id="mg-ai-key" placeholder="sk-...">
      </div>
      <div class="mg-col-3 mg-field">
        <label for="mg-ai-model">Model</label>
        <input type="text" id="mg-ai-model" placeholder="gpt-4o-mini">
      </div>
      <div class="mg-col-2 mg-field">
        <label for="mg-ai-auth">Auth Style</label>
        <select id="mg-ai-auth">
          <option value="bearer">Bearer token</option>
          <option value="x_api_key">x-api-key (Anthropic)</option>
          <option value="api_key">api-key (Azure)</option>
        </select>
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-grow mg-field">
        <label for="mg-ai-context">System Prompt <span class="mg-text-muted">(optional)</span></label>
        <input type="text" id="mg-ai-context" placeholder="e.g. This is an e-commerce analytics database with 50M orders">
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-grow mg-field">
        <label for="mg-ai-domain">Domain Prompt <span class="mg-text-muted">(optional)</span></label>
        <input type="text" id="mg-ai-domain" placeholder="e.g. Prefer window functions over correlated subqueries">
      </div>
    </div>
    <div class="mg-row">
      <div class="mg-col-grow mg-field">
        <label for="mg-ai-max-tokens">Max Tokens <span id="mg-ai-max-tokens-val" style="font-weight:400;">4096</span></label>
        <input type="range" id="mg-ai-max-tokens" min="256" max="16384" step="256" value="4096" style="width:100%;cursor:pointer;">
        <div style="display:flex;justify-content:space-between;font-size:10px;color:#888;">
          <span>256</span><span>1k</span><span>2k</span><span>4k</span><span>8k</span><span>16k</span>
        </div>
      </div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <button id="mg-ai-save" class="mg-btn mg-btn-primary mg-btn-sm">Save</button>
      <span id="mg-ai-save-status" style="font-size:12px;"></span>
    </div>
  </div>
</div>

<script>
(function() {
  var currentProfile = null;
  var editingName = null;

  function el(id) { return document.getElementById(id); }
  function show(e) { e.classList.remove('mg-hidden'); }
  function hide(e) { e.classList.add('mg-hidden'); }

  function loadProfiles() {
    fetch('/api/profiles').then(function(r) { return r.json(); }).then(function(data) {
      currentProfile = data.current;
      var tbody = el('mg-profile-tbody');
      if (!data.profiles.length) {
        tbody.innerHTML = '<tr><td colspan="5" class="mg-text-muted">No profiles configured. Click "Add Profile" to create one.</td></tr>';
        return;
      }
      tbody.innerHTML = data.profiles.map(function(p) {
        var isCurrent = p.name === data.current;
        var badge = isCurrent ? '<span class="mg-badge mg-badge-success">Active</span>' : '';
        var connectBtn = isCurrent ? '' : '<button class="mg-btn mg-btn-outline mg-btn-sm mg-connect-btn" data-name="' + p.name + '">Connect</button> ';
        var deleteBtn = isCurrent ? '' : '<button class="mg-btn mg-btn-outline-danger mg-btn-sm mg-delete-btn" data-name="' + p.name + '">Delete</button>';
        return '<tr>' +
          '<td><strong>' + p.name + '</strong></td>' +
          '<td>' + (p.mysql.host || '') + ':' + (p.mysql.port || 3306) + '</td>' +
          '<td>' + (p.mysql.database || '') + '</td>' +
          '<td>' + badge + '</td>' +
          '<td>' + connectBtn +
            '<button class="mg-btn mg-btn-outline-secondary mg-btn-sm mg-edit-btn" data-name="' + p.name + '">Edit</button> ' +
            deleteBtn +
          '</td></tr>';
      }).join('');
    });
  }

  function getFormData() {
    return {
      host: el('mg-f-host').value, port: parseInt(el('mg-f-port').value) || 3306,
      username: el('mg-f-username').value, password: el('mg-f-password').value,
      database: el('mg-f-database').value, tls_mode: el('mg-f-tls').value,
    };
  }

  function fillForm(profile) {
    var m = profile.mysql || {};
    el('mg-f-name').value = profile.name || '';
    el('mg-f-host').value = m.host || '';
    el('mg-f-port').value = m.port || 3306;
    el('mg-f-username').value = m.username || '';
    el('mg-f-password').value = m.password || '';
    el('mg-f-database').value = m.database || '';
    el('mg-f-tls').value = m.tls_mode || 'preferred';
  }

  function clearForm() {
    el('mg-f-name').value = ''; el('mg-f-host').value = '';
    el('mg-f-port').value = '3306'; el('mg-f-username').value = '';
    el('mg-f-password').value = ''; el('mg-f-database').value = '';
    el('mg-f-tls').value = 'preferred'; el('mg-form-status').textContent = '';
    editingName = null;
  }

  el('mg-add-profile-btn').addEventListener('click', function() {
    clearForm();
    el('mg-f-name').disabled = false;
    el('mg-form-title').textContent = 'Add Profile';
    show(el('mg-profile-form'));
  });

  el('mg-form-cancel').addEventListener('click', function() {
    hide(el('mg-profile-form'));
    clearForm();
  });

  el('mg-form-test').addEventListener('click', function() {
    el('mg-form-status').textContent = 'Testing...';
    el('mg-form-status').style.color = '';
    fetch('/api/test_connection', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mysql: getFormData() })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          el('mg-form-status').textContent = 'Connected (MySQL ' + data.version + ')';
          el('mg-form-status').style.color = '#1a7f37';
        } else {
          el('mg-form-status').textContent = 'Failed: ' + data.error;
          el('mg-form-status').style.color = '#cf222e';
        }
      });
  });

  el('mg-form-save').addEventListener('click', function() {
    var name = el('mg-f-name').value.trim();
    if (!name) { alert('Profile name is required.'); return; }
    var mysql = getFormData();
    var url, method;
    if (editingName) {
      url = '/api/profiles/' + encodeURIComponent(editingName);
      method = 'PUT';
    } else {
      url = '/api/profiles';
      method = 'POST';
    }
    fetch(url, { method: method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, mysql: mysql }) })
      .then(function(r) { return r.json().then(function(d) { return { status: r.status, body: d }; }); })
      .then(function(res) {
        if (res.status >= 400) { alert(res.body.error || 'Save failed'); return; }
        hide(el('mg-profile-form'));
        clearForm();
        loadProfiles();
      });
  });

  document.addEventListener('click', function(e) {
    var btn;
    btn = e.target.closest('.mg-connect-btn');
    if (btn) {
      btn.disabled = true; btn.textContent = 'Connecting...';
      fetch('/api/profiles/' + encodeURIComponent(btn.dataset.name) + '/connect', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) { loadProfiles(); }
          else { alert('Connect failed: ' + data.error); btn.disabled = false; btn.textContent = 'Connect'; }
        });
      return;
    }
    btn = e.target.closest('.mg-edit-btn');
    if (btn) {
      fetch('/api/profiles').then(function(r) { return r.json(); }).then(function(data) {
        var p = data.profiles.find(function(x) { return x.name === btn.dataset.name; });
        if (p) {
          fillForm(p); editingName = p.name;
          el('mg-f-name').value = p.name; el('mg-f-name').disabled = true;
          el('mg-form-title').textContent = 'Edit Profile: ' + p.name;
          show(el('mg-profile-form'));
        }
      });
      return;
    }
    btn = e.target.closest('.mg-delete-btn');
    if (btn) {
      if (!confirm('Delete profile "' + btn.dataset.name + '"?')) return;
      fetch('/api/profiles/' + encodeURIComponent(btn.dataset.name), { method: 'DELETE' })
        .then(function(r) { return r.json(); })
        .then(function() { loadProfiles(); });
    }
  });

  loadProfiles();

  // --- AI Configuration ---

  var AI_PROVIDERS = {
    openai:    { endpoint: 'https://api.openai.com/v1/chat/completions',       model: 'gpt-4o-mini',                  auth: 'bearer',  keyPlaceholder: 'sk-...' },
    anthropic: { endpoint: 'https://api.anthropic.com/v1/messages',            model: 'claude-sonnet-4-20250514',     auth: 'x_api_key', keyPlaceholder: 'sk-ant-...' },
    google:    { endpoint: 'https://generativelanguage.googleapis.com/v1beta/openai/chat/completions', model: 'gemini-2.0-flash', auth: 'bearer', keyPlaceholder: 'AIza...' },
    azure:     { endpoint: 'https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT/chat/completions?api-version=2024-02-01', model: '', auth: 'api_key', keyPlaceholder: 'your-azure-key' },
    deepseek:  { endpoint: 'https://api.deepseek.com/chat/completions',        model: 'deepseek-chat',                auth: 'bearer',  keyPlaceholder: 'sk-...' },
    openrouter:{ endpoint: 'https://openrouter.ai/api/v1/chat/completions',    model: 'openai/gpt-4o-mini',           auth: 'bearer',  keyPlaceholder: 'sk-or-...' },
    groq:      { endpoint: 'https://api.groq.com/openai/v1/chat/completions',  model: 'llama-3.3-70b-versatile',      auth: 'bearer',  keyPlaceholder: 'gsk_...' },
    mistral:   { endpoint: 'https://api.mistral.ai/v1/chat/completions',       model: 'mistral-small-latest',         auth: 'bearer',  keyPlaceholder: 'your-mistral-key' },
    xai:       { endpoint: 'https://api.x.ai/v1/chat/completions',             model: 'grok-2',                       auth: 'bearer',  keyPlaceholder: 'xai-...' },
    together:  { endpoint: 'https://api.together.xyz/v1/chat/completions',     model: 'meta-llama/Llama-3.3-70B-Instruct-Turbo', auth: 'bearer', keyPlaceholder: 'your-together-key' },
    fireworks: { endpoint: 'https://api.fireworks.ai/inference/v1/chat/completions', model: 'accounts/fireworks/models/llama-v3p3-70b-instruct', auth: 'bearer', keyPlaceholder: 'fw_...' },
    ollama:    { endpoint: 'http://localhost:11434/v1/chat/completions',        model: 'llama3.2',                     auth: 'bearer',  keyPlaceholder: '(not required)' },
    perplexity:{ endpoint: 'https://api.perplexity.ai/chat/completions',      model: 'sonar',                        auth: 'bearer',  keyPlaceholder: 'pplx-...' },
    lmstudio:  { endpoint: 'http://localhost:1234/v1/chat/completions',         model: '',                             auth: 'bearer',  keyPlaceholder: '(not required)' },
    custom:    { endpoint: '',                                                  model: '',                             auth: 'bearer',  keyPlaceholder: 'your-api-key' }
  };

  el('mg-ai-provider').addEventListener('change', function() {
    var preset = AI_PROVIDERS[this.value];
    if (!preset) return;
    el('mg-ai-endpoint').value = preset.endpoint;
    el('mg-ai-model').value = preset.model;
    el('mg-ai-auth').value = preset.auth;
    el('mg-ai-key').placeholder = preset.keyPlaceholder;
    if (this.value === 'ollama') {
      el('mg-ai-key').value = 'ollama';
    }
  });

  function detectProvider(endpoint) {
    if (!endpoint) return 'custom';
    if (endpoint.includes('openai.azure.com')) return 'azure';
    if (endpoint.includes('api.openai.com')) return 'openai';
    if (endpoint.includes('anthropic.com')) return 'anthropic';
    if (endpoint.includes('generativelanguage.googleapis.com')) return 'google';
    if (endpoint.includes('api.deepseek.com')) return 'deepseek';
    if (endpoint.includes('openrouter.ai')) return 'openrouter';
    if (endpoint.includes('api.groq.com')) return 'groq';
    if (endpoint.includes('api.mistral.ai')) return 'mistral';
    if (endpoint.includes('api.x.ai')) return 'xai';
    if (endpoint.includes('api.together.xyz')) return 'together';
    if (endpoint.includes('api.fireworks.ai')) return 'fireworks';
    if (endpoint.includes('api.perplexity.ai')) return 'perplexity';
    if (endpoint.includes('localhost:11434') || endpoint.includes('127.0.0.1:11434')) return 'ollama';
    if (endpoint.includes('localhost:1234') || endpoint.includes('127.0.0.1:1234')) return 'lmstudio';
    return 'custom';
  }

  var maxTokensSlider = el('mg-ai-max-tokens');
  var maxTokensVal = el('mg-ai-max-tokens-val');
  maxTokensSlider.addEventListener('input', function() {
    maxTokensVal.textContent = Number(this.value).toLocaleString();
  });

  function loadAiConfig() {
    fetch('/api/ai_config').then(function(r) { return r.json(); }).then(function(data) {
      el('mg-ai-endpoint').value = data.endpoint || '';
      el('mg-ai-key').value = data.api_key || '';
      el('mg-ai-model').value = data.model || '';
      el('mg-ai-auth').value = data.auth_style || 'bearer';
      el('mg-ai-context').value = data.system_context || '';
      el('mg-ai-domain').value = data.domain_context || '';
      var tokens = parseInt(data.max_tokens) || 4096;
      maxTokensSlider.value = tokens;
      maxTokensVal.textContent = tokens.toLocaleString();
      el('mg-ai-provider').value = detectProvider(data.endpoint);
      var enabled = (data.endpoint && data.api_key);
      el('mg-ai-status').textContent = enabled ? 'Configured' : 'Not configured';
      el('mg-ai-status').style.color = enabled ? '#1a7f37' : '#888';
    });
  }

  el('mg-ai-save').addEventListener('click', function() {
    var payload = {
      endpoint: el('mg-ai-endpoint').value.trim(),
      api_key: el('mg-ai-key').value.trim(),
      model: el('mg-ai-model').value.trim(),
      auth_style: el('mg-ai-auth').value,
      system_context: el('mg-ai-context').value.trim(),
      domain_context: el('mg-ai-domain').value.trim(),
      max_tokens: parseInt(maxTokensSlider.value) || 4096
    };
    el('mg-ai-save-status').textContent = 'Saving...';
    el('mg-ai-save-status').style.color = '';
    fetch('/api/ai_config', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.error) {
        el('mg-ai-save-status').textContent = 'Error: ' + data.error;
        el('mg-ai-save-status').style.color = '#cf222e';
      } else {
        el('mg-ai-save-status').textContent = 'Saved';
        el('mg-ai-save-status').style.color = '#1a7f37';
        loadAiConfig();
        setTimeout(function() { el('mg-ai-save-status').textContent = ''; }, 3000);
      }
    });
  });

  loadAiConfig();
})();
</script>
